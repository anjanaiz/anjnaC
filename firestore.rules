rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Event Dashboard: Allow real-time synchronization across all devices and browsers
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /timeline/{dayId} {
      allow read, write: if true;
    }

    match /stalls/{stallId} {
      allow read, write: if true;
    }

    match /general_tasks/{taskId} {
      allow read, write: if true;
    }

    match /map_markers/{markerId} {
      allow read, write: if true;
    }

    match /map_categories/{catId} {
      allow read, write: if true;
    }

    match /event_requirements/{reqId} {
      allow read, write: if true;
    }

    match /settings/{settingsId} {
      allow read, write: if true;
    }
  }
}
